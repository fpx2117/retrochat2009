# RetroChat 2009 - Variables de Entorno
# =========================================
# Copiá este archivo a .env.local y completá los valores
# NUNCA commitees .env.local con tus claves reales

# ── Database (Railway PostgreSQL) ─────────────────────────────
# Connection string para Prisma (obtenela de Railway → Connect)
DATABASE_URL=postgresql://postgres:iCsHTATeiqlllWxdejCwWuVcBfvBuCVe@zephyr.proxy.rlwy.net:59828/railway

# ── Autenticación ────────────────────────────────────────────
# Clave secreta para firmar JWTs (generá una random de 32+ chars)
# Podés generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-clave-segura-de-32-caracteres

# ── Configuración de la app ──────────────────────────────────
# URL de tu app (en desarrollo: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Deploy (Vercel/Railway) ───────────────────────────────────
# Estos se configuran automáticamente en Vercel
# VERCEL_URL se genera automáticamente en Vercel
